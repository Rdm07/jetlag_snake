box-sizing: border-box; color: rgb(255, 255, 255); font-size: 0.87em; left:=
 24px; max-width: 568px; min-width: 288px; opacity: 0; padding: 16px 24px 1=
2px; position: fixed; transform: translateY(90px); will-change: opacity, tr=
ansform; z-index: 999; }

.snackbar-show { animation: 250ms cubic-bezier(0, 0, 0.2, 1) 0s 1 normal fo=
